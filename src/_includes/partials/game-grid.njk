<div class="game-filter" id="game-filter">
  <div class="game-filter__options">
    <button class="game-filter__icon-btn" id="filter-favorites" aria-label="Favorites" title="Favorites" onclick="filterFavorites()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
    </button>
    <button class="game-filter__icon-btn" id="filter-recent" aria-label="Recently played" title="Recently played" onclick="filterRecent()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="game-filter__icon-btn" id="view-toggle" aria-label="Toggle list view" title="Toggle view" onclick="toggleView()">
      <svg id="view-icon-list" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      <svg id="view-icon-grid" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" style="display:none"><rect x="3" y="3" width="7" height="7" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="14" width="7" height="7" stroke="currentColor" stroke-width="1.5"/></svg>
    </button>
    <div class="game-filter__dropdown-wrap">
      <button class="game-filter__icon-btn" id="cat-toggle" aria-label="Filter by category" title="Category" onclick="document.getElementById('cat-dropdown').classList.toggle('open')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="3" width="7" height="7" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="3" width="7" height="7" stroke="currentColor" stroke-width="1.5"/><rect x="3" y="14" width="7" height="7" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="14" width="7" height="7" stroke="currentColor" stroke-width="1.5"/></svg>
      </button>
      <div class="game-filter__dropdown" id="cat-dropdown">
        <button onclick="filterGames('all');this.parentElement.classList.remove('open')" class="game-filter__dropdown-item active" data-filter="all">All</button>
        {% for cat in categories %}
          <button onclick="filterGames('{{ cat.slug }}');this.parentElement.classList.remove('open')" class="game-filter__dropdown-item" data-filter="{{ cat.slug }}">{{ cat.label }}</button>
        {% endfor %}
      </div>
    </div>
    <div class="game-filter__dropdown-wrap">
      <button class="game-filter__icon-btn" id="az-toggle" aria-label="Filter by letter" title="A-Z" onclick="document.getElementById('az-dropdown').classList.toggle('open')">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 18h7l-3.5-12L3 18zM5.5 14h3M15 6v12M15 18l3-3M15 18l-3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="game-filter__dropdown" id="az-dropdown">
        <button onclick="filterByLetter('all');this.parentElement.classList.remove('open')" class="game-filter__dropdown-item active" data-letter="all">All</button>
        {% for letter in "ABCDEFGHIJKLMNOPQRSTUVWXYZ" %}<button onclick="filterByLetter('{{ letter }}');this.parentElement.classList.remove('open')" class="game-filter__dropdown-item" data-letter="{{ letter }}">{{ letter }}</button>{% endfor %}
      </div>
    </div>
    <button class="game-filter__icon-btn" id="search-toggle" aria-label="Search" title="Search" onclick="toggleSearch()">
      <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.5"/><path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    </button>
  </div>
  <input type="search" id="game-search" class="game-filter__search game-filter__search--hidden" placeholder="Search games..." oninput="searchGames(this.value)" aria-label="Search games">
</div>

<div class="game-grid" id="game-grid">
  {% for g in gameList %}
    {% include "partials/game-card.njk" %}
  {% endfor %}
</div>

<p class="game-grid__empty" id="no-results" hidden>No games match your search.</p>
