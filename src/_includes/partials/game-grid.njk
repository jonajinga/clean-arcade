<div class="game-filter" id="game-filter">
  <div class="game-filter__options">
    <label class="sr-only" for="category-select">Category</label>
    <select id="category-select" class="game-filter__sort" onchange="filterGames(this.value)">
      <option value="all">All Categories</option>
      {% for cat in categories %}
        <option value="{{ cat.slug }}">{{ cat.label }}</option>
      {% endfor %}
    </select>
    <label class="sr-only" for="sort-select">Sort by</label>
    <select id="sort-select" class="game-filter__sort" onchange="sortGames(this.value)">
      <option value="title">A-Z</option>
      <option value="newest">Newest</option>
    </select>
    <input type="search" id="game-search" class="game-filter__search" placeholder="Search games..." oninput="searchGames(this.value)" aria-label="Search games">
  </div>
</div>

<div class="game-grid" id="game-grid">
  {% for g in gameList %}
    {% include "partials/game-card.njk" %}
  {% endfor %}
</div>

<p class="game-grid__empty" id="no-results" hidden>No games match your search.</p>
