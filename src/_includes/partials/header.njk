<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo" aria-label="{{ meta.title }} — Home">
      <span class="logo-icon" aria-hidden="true">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="2" y="6" width="24" height="16" rx="3" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="14" r="2" fill="currentColor"/><circle cx="19" cy="14" r="2" fill="currentColor"/><rect x="13" y="11" width="2" height="6" rx="1" fill="currentColor"/></svg>
      </span>
      <span class="logo-text">{{ meta.shortTitle }}</span>
    </a>

    <nav class="site-nav" aria-label="Main navigation">
      <ul class="site-nav__list">
        {% for item in navigation %}
          <li>
            <a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% elif page.url | startsWith(item.url) and item.url != "/" %} aria-current="page"{% endif %}>
              {{ item.label }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>

    <div class="site-header__actions">
      <div class="gtranslate_wrapper"></div>
      {% include "partials/theme-toggle.njk" %}
      <button class="search-toggle" onclick="openSearch()" aria-label="Search games">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.5"/><path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <button class="hamburger-btn" id="hamburger-btn" onclick="openHamburger()" aria-label="Open menu" aria-expanded="false" aria-controls="hamburger-panel">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</header>
