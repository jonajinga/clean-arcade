<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo" aria-label="{{ meta.title }} — Home">
      <svg class="logo-icon" width="24" height="24" viewBox="0 0 28 28" fill="none" aria-hidden="true"><rect x="2" y="6" width="24" height="16" stroke="currentColor" stroke-width="2"/><circle cx="9" cy="14" r="2" fill="currentColor"/><circle cx="19" cy="14" r="2" fill="currentColor"/><rect x="13" y="11" width="2" height="6" fill="currentColor"/></svg>
      <span class="logo-text">{{ meta.shortTitle }}</span>
    </a>

    <div class="site-header__actions">
      <button class="icon-btn" onclick="openSearch()" aria-label="Search" title="Search (Ctrl+K)">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.5"/><path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <button class="icon-btn" onclick="toggleTheme()" aria-label="Toggle dark mode" title="Toggle theme">
        <svg class="theme-icon__sun" width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.93 4.93l1.41 1.41M13.66 13.66l1.41 1.41M4.93 15.07l1.41-1.41M13.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        <svg class="theme-icon__moon" width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M17 11a7 7 0 11-8-8 5.5 5.5 0 008 8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="icon-btn hamburger-btn" id="hamburger-btn" onclick="openHamburger()" aria-label="Menu" aria-expanded="false" aria-controls="hamburger-panel" title="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</header>
