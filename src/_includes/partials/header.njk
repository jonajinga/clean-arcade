<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo" aria-label="{{ meta.title }} — Home">
      <svg class="logo-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><rect x="1" y="1" width="16" height="16" stroke="currentColor" stroke-width="2"/><rect x="5" y="5" width="3" height="3" fill="currentColor"/><rect x="10" y="10" width="3" height="3" fill="currentColor"/></svg>
      <span class="logo-text">{{ meta.shortTitle }}</span>
    </a>
    <button class="icon-btn" id="hamburger-btn" onclick="openHamburger()" aria-label="Menu" aria-expanded="false" aria-controls="hamburger-panel" title="Menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
  </div>
</header>
