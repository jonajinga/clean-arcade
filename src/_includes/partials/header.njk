<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo" aria-label="{{ meta.title }} — Home">
      <svg class="logo-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><rect x="1" y="1" width="16" height="16" stroke="currentColor" stroke-width="2"/><rect x="5" y="5" width="3" height="3" fill="currentColor"/><rect x="10" y="10" width="3" height="3" fill="currentColor"/></svg>
    </a>

    {# Filter buttons — only visible on home page #}
    <div class="site-header__filters" id="header-filters">
      <button class="site-header__filter-btn" id="filter-favorites" aria-label="Favorites" title="Favorites" onclick="filterFavorites()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
      </button>
      <button class="site-header__filter-btn" id="filter-recent" aria-label="Recently played" title="Recently played" onclick="filterRecent()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <div class="game-filter__dropdown-wrap">
        <button class="site-header__filter-btn" id="cat-toggle" aria-label="Filter by category" title="Category" onclick="toggleDropdown('cat-dropdown')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h6v6H4zM14 4h6v2h-6zM14 10h6v2h-6zM4 16h16v2H4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="game-filter__dropdown" id="cat-dropdown" role="menu">
          <button onclick="filterGames('all');this.parentElement.classList.remove('open')" class="game-filter__dropdown-item active" data-filter="all">All</button>
          {% for cat in categories %}
            <button onclick="filterGames('{{ cat.slug }}');this.parentElement.classList.remove('open')" class="game-filter__dropdown-item" data-filter="{{ cat.slug }}">{{ cat.label }}</button>
          {% endfor %}
        </div>
      </div>
      <div class="game-filter__dropdown-wrap">
        <button class="site-header__filter-btn" id="az-toggle" aria-label="Filter by letter" title="A-Z" onclick="toggleDropdown('az-dropdown')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 18h7l-3.5-12L3 18zM5.5 14h3M15 6v12M15 18l3-3M15 18l-3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="game-filter__dropdown" id="az-dropdown" role="menu">
          <button onclick="filterByLetter('all');this.parentElement.classList.remove('open')" class="game-filter__dropdown-item active" data-letter="all">All</button>
          {% for letter in "ABCDEFGHIJKLMNOPQRSTUVWXYZ" %}<button onclick="filterByLetter('{{ letter }}');this.parentElement.classList.remove('open')" class="game-filter__dropdown-item" data-letter="{{ letter }}">{{ letter }}</button>{% endfor %}
        </div>
      </div>
      <button class="site-header__filter-btn" id="search-toggle" aria-label="Search" title="Search" onclick="openSearch()">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.5"/><path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
      <button class="site-header__filter-btn" id="clear-filters" aria-label="Clear filters" title="Clear filters" onclick="clearAllFilters()" style="display:none">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
      </button>
    </div>

    {# Game controls — only visible on game pages #}
    <div class="site-header__game-controls" id="game-controls">
      <button class="site-header__filter-btn" id="fav-btn" title="Favorite" onclick="toggleFavorite(GAME_SLUG)">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path id="heart-path" d="M8 14s-5.5-3.5-5.5-7A3 3 0 018 4.5 3 3 0 0113.5 7C13.5 10.5 8 14 8 14z" stroke="currentColor" stroke-width="1.3" fill="none"/></svg>
      </button>
      <button class="site-header__filter-btn" id="info-toggle" title="Game info">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z" stroke="currentColor" stroke-width="1.5"/><path d="M12 16v-4M12 8h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
      <button class="site-header__filter-btn" id="share-btn" title="Share">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="12" cy="4" r="2" stroke="currentColor" stroke-width="1.2"/><circle cx="4" cy="8" r="2" stroke="currentColor" stroke-width="1.2"/><circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.2"/><path d="M6 7l4-2M6 9l4 2" stroke="currentColor" stroke-width="1.2"/></svg>
      </button>
    </div>

    {# Global buttons + count — always visible, right side #}
    <div class="site-header__global">
      <div class="game-filter__dropdown-wrap" id="gt-wrap">
        <button class="site-header__filter-btn" id="translate-btn" aria-label="Translate" title="Translate" onclick="var d=document.getElementById('gt-dropdown');d.classList.toggle('open')">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><ellipse cx="8" cy="8" rx="3" ry="7" stroke="currentColor" stroke-width="1.3"/><path d="M1 8h14" stroke="currentColor" stroke-width="1.3"/></svg>
        </button>
        <div class="game-filter__dropdown" id="gt-dropdown" style="right:0;left:auto;">
          <div class="gtranslate_wrapper"></div>
        </div>
      </div>
      <a href="/info/" class="site-header__filter-btn" aria-label="About" title="About">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 016.5 17H20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z" stroke="currentColor" stroke-width="1.5"/></svg>
      </a>
      <span class="site-header__separator">|</span>
      <span class="site-header__count">{{ games | length }}</span>
    </div>
  </div>
</header>
