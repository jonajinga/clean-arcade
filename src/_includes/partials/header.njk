<header class="site-header" id="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-header__logo" aria-label="{{ meta.title }} — Home">
      <svg class="logo-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true"><rect x="1" y="1" width="16" height="16" stroke="currentColor" stroke-width="2"/><rect x="5" y="5" width="3" height="3" fill="currentColor"/><rect x="10" y="10" width="3" height="3" fill="currentColor"/></svg>
      <span class="logo-text">{{ meta.shortTitle }}</span>
    </a>
    <div class="site-header__actions">
      <a href="/my-games/#favorites" class="icon-btn" aria-label="Favorites" title="Favorites">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
      </a>
      <a href="/my-games/#recent" class="icon-btn" aria-label="Recently played" title="Recently played">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <button class="icon-btn" id="hamburger-btn" onclick="openHamburger()" aria-label="Menu" aria-expanded="false" aria-controls="hamburger-panel" title="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>
</header>
