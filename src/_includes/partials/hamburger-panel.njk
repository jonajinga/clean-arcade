<div class="hamburger-panel" id="hamburger-panel" aria-hidden="true">
  <div class="hamburger-panel__overlay" onclick="closeHamburger()"></div>
  <div class="hamburger-panel__content" role="dialog" aria-label="Menu">
    <div class="hamburger-panel__top">
      <span class="hamburger-panel__title">Clean Arcade <span class="hamburger-panel__count">| {{ games | length }}</span></span>
      <button class="icon-btn" onclick="closeHamburger()" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>

    <nav aria-label="Navigation">
      <div class="hamburger-panel__btn-grid">
        <a href="/" onclick="closeHamburger()" aria-label="Games" title="Games" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 2l2 4h8l2-4M4 8h16v12H4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="9" cy="14" r="1.5" fill="currentColor"/><circle cx="15" cy="14" r="1.5" fill="currentColor"/></svg>
        </a>
        <a href="/my-games/" onclick="closeHamburger()" aria-label="My Games" title="My Games" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
        </a>
        <a href="/info/" onclick="closeHamburger()" aria-label="Info" title="Info" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 11v6M12 7.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
        <button class="hamburger-panel__grid-btn" onclick="closeHamburger();openSearch()" aria-label="Search" title="Search">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.5"/><path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <button class="hamburger-panel__grid-btn" id="translate-btn" aria-label="Translate" title="Translate" onclick="document.getElementById('gt-select').classList.toggle('hidden')">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><ellipse cx="8" cy="8" rx="3" ry="7" stroke="currentColor" stroke-width="1.3"/><path d="M1 8h14" stroke="currentColor" stroke-width="1.3"/></svg>
        </button>
        <a href="/sitemap.xml" onclick="closeHamburger()" aria-label="Sitemap" title="Sitemap" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v8M12 14v8M2 12h8M14 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.5"/></svg>
        </a>
      </div>
    </nav>

    {# GTranslate dropdown #}
    <div class="gt-select-wrap" id="gt-select">
      <div class="gtranslate_wrapper"></div>
    </div>
  </div>
</div>
