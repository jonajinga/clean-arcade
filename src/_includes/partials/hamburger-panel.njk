<div class="hamburger-panel" id="hamburger-panel" aria-hidden="true">
  <div class="hamburger-panel__overlay" onclick="closeHamburger()"></div>
  <div class="hamburger-panel__content" role="dialog" aria-label="Menu">
    <div class="hamburger-panel__top">
      <span class="hamburger-panel__title">Clean Arcade <span class="hamburger-panel__count">| {{ games | length }}</span></span>
      <button class="icon-btn" onclick="closeHamburger()" aria-label="Close menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>

    {# All buttons in one grid #}
    <nav aria-label="Navigation">
      <div class="hamburger-panel__btn-grid">
        {# Primary pages #}
        <a href="/" onclick="closeHamburger()" aria-label="Games" title="Games" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 2l2 4h8l2-4M4 8h16v12H4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><circle cx="9" cy="14" r="1.5" fill="currentColor"/><circle cx="15" cy="14" r="1.5" fill="currentColor"/></svg>
        </a>
        <a href="/my-games/" onclick="closeHamburger()" aria-label="My Games" title="My Games" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" stroke="currentColor" stroke-width="1.5" fill="none"/></svg>
        </a>
        <a href="/features/" onclick="closeHamburger()" aria-label="Features" title="Features" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </a>
        {# Utility actions #}
        <button class="hamburger-panel__grid-btn" onclick="closeHamburger();openSearch()" aria-label="Search" title="Search">
          <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.5"/><path d="M13 13l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <button class="hamburger-panel__grid-btn" onclick="toggleTheme()" aria-label="Toggle theme" title="Toggle theme">
          <svg class="theme-icon__sun" width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.93 4.93l1.41 1.41M13.66 13.66l1.41 1.41M4.93 15.07l1.41-1.41M13.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <svg class="theme-icon__moon" width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M17 11a7 7 0 11-8-8 5.5 5.5 0 008 8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <button class="hamburger-panel__grid-btn" id="translate-btn" aria-label="Translate" title="Translate" onclick="document.getElementById('gt-select').classList.toggle('hidden')">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><ellipse cx="8" cy="8" rx="3" ry="7" stroke="currentColor" stroke-width="1.3"/><path d="M1 8h14" stroke="currentColor" stroke-width="1.3"/></svg>
        </button>
        {# Secondary pages #}
        <a href="/about/" onclick="closeHamburger()" aria-label="About" title="About" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 11v6M12 7.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
        <a href="/blog/" onclick="closeHamburger()" aria-label="Blog" title="Blog" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 4h16v16H4z" stroke="currentColor" stroke-width="1.5"/><path d="M8 8h8M8 12h5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
        <a href="/changelog/" onclick="closeHamburger()" aria-label="Changelog" title="Changelog" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/><path d="M12 6v6l4 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/privacy-policy/" onclick="closeHamburger()" aria-label="Privacy Policy" title="Privacy" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l8 4v6c0 5.25-3.5 9.75-8 11-4.5-1.25-8-5.75-8-11V6l8-4z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></svg>
        </a>
        <a href="/style-guide/" onclick="closeHamburger()" aria-label="Style Guide" title="Style Guide" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 3h7v7H3zM14 3h7v7h-7zM3 14h7v7H3zM14 14h7v7h-7z" stroke="currentColor" stroke-width="1.5"/></svg>
        </a>
        <a href="/feed.xml" onclick="closeHamburger()" aria-label="RSS Feed" title="RSS" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="6" cy="18" r="2" fill="currentColor"/><path d="M4 4a16 16 0 0116 16M4 11a9 9 0 019 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </a>
        <a href="/sitemap.xml" onclick="closeHamburger()" aria-label="Sitemap" title="Sitemap" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2v8M12 14v8M2 12h8M14 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.5"/></svg>
        </a>
        <a href="mailto:{{ meta.email }}" aria-label="Email" title="{{ meta.email }}" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M22 4L12 13 2 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="https://www.pikespeakwebdesigns.com" target="_blank" rel="noopener" aria-label="Pikes Peak Web Designs" title="Pikes Peak Web Designs" class="hamburger-panel__grid-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 17L17 7M17 7H7M17 7v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </nav>

    {# GTranslate dropdown #}
    <div class="gt-select-wrap" id="gt-select">
      <div class="gtranslate_wrapper"></div>
    </div>
  </div>
</div>
