<div class="mp-panel" id="mp-panel">
  <div class="mp-panel__row">
    <input type="text" id="mp-name" class="mp-input" placeholder="Your name" maxlength="20" autocomplete="off" value="">
  </div>
  <div class="mp-panel__row">
    <button class="mp-btn" id="mp-create">Create Room</button>
    <input type="text" id="mp-code" class="mp-input mp-input--code" placeholder="Code" maxlength="6" autocomplete="off">
    <button class="mp-btn" id="mp-join">Join</button>
  </div>
  <div class="mp-panel__status" id="mp-status" hidden>
    <span id="mp-room-display"></span>
    <span id="mp-peers">0 peers</span>
  </div>
</div>
