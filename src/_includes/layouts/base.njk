<!DOCTYPE html>
<html lang="{{ meta.language }}" data-mode="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ meta.shortTitle }}</title>
  <meta name="description" content="{{ description or meta.description }}">
  <meta name="author" content="{{ meta.author }}">
  <meta name="theme-color" content="{{ meta.themeColor }}">
  <link rel="canonical" href="{{ meta.url }}{{ page.url }}">

  {# Favicon + PWA #}
  <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/assets/img/icon-192.svg">
  <link rel="manifest" href="/manifest.json">

  {# Open Graph #}
  <meta property="og:title" content="{{ title }} | {{ meta.shortTitle }}">
  <meta property="og:description" content="{{ description or meta.description }}">
  <meta property="og:url" content="{{ meta.url }}{{ page.url }}">
  <meta property="og:image" content="{{ meta.url }}{{ ogImage or meta.ogImage }}">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="{{ meta.locale }}">
  <meta property="og:site_name" content="{{ meta.title }}">

  {# Twitter Card #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} | {{ meta.shortTitle }}">
  <meta name="twitter:description" content="{{ description or meta.description }}">
  <meta name="twitter:image" content="{{ meta.url }}{{ ogImage or meta.ogImage }}">

  {# Bunny Fonts #}
  <link rel="preconnect" href="https://fonts.bunny.net">
  <link href="https://fonts.bunny.net/css?family=inter:400,500,600,700|space-grotesk:500,600,700" rel="stylesheet">

  {# CSS #}
  <link rel="stylesheet" href="/assets/css/global.css?v={{ "" | year }}">

  {# Dark mode — inline to prevent flash #}
  <script>
    (function(){
      var m = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme:dark)").matches ? "dark" : "light");
      document.documentElement.setAttribute("data-mode", m);
    })();
  </script>

  {# RSS #}
  <link rel="alternate" type="application/atom+xml" title="{{ meta.title }}" href="{{ meta.url }}/feed.xml">

  {# JSON-LD #}
  {% include "partials/schema-org.njk" %}
</head>
<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
  <a class="skip-link" href="#main">Skip to content</a>

  {% include "partials/header.njk" %}
  {% include "partials/hamburger-panel.njk" %}

  <main id="main">
    {{ content | safe }}
  </main>


  {# Back to top #}
  <button class="back-to-top" aria-label="Back to top" title="Back to top" onclick="window.scrollTo({top:0,behavior:'smooth'})">
    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 3L3 10h4v7h6v-7h4L10 3z" fill="currentColor"/></svg>
  </button>

  {# GTranslate — dropdown mode, not floating #}
  <script>
    window.gtranslateSettings = {
      default_language: "en",
      languages: ["en","af","sq","am","ar","hy","az","eu","be","bn","bs","bg","ca","ceb","zh-CN","zh-TW","co","hr","cs","da","nl","eo","et","fi","fr","fy","gl","ka","de","el","gu","ht","ha","haw","he","hi","hmn","hu","is","ig","id","ga","it","ja","jv","kn","kk","km","rw","ko","ku","ky","lo","la","lv","lt","lb","mk","mg","ms","ml","mt","mi","mr","mn","my","ne","no","ny","or","ps","fa","pl","pt","pa","ro","ru","sm","gd","sr","st","sn","sd","si","sk","sl","so","es","su","sw","sv","tl","tg","ta","tt","te","th","tr","tk","uk","ur","ug","uz","vi","cy","xh","yi","yo","zu"],
      wrapper_selector: ".gtranslate_wrapper",
      flag_style: "3d",
      alt_flags: {"en":"usa"}
    };
  </script>
  <script src="https://cdn.gtranslate.net/widgets/latest/dropdown.js" defer></script>

  {# Site JS — Pagefind loaded dynamically by search.js #}
  <script src="/assets/js/theme-toggle.js" defer></script>
  <script src="/assets/js/nav.js" defer></script>
  <script src="/assets/js/search.js" defer></script>

  {# Back to top + header show/hide on game pages #}
  <script>
    (function(){
      var btn = document.querySelector(".back-to-top");
      var header = document.getElementById("site-header");
      var isGame = document.body.classList.contains("game-active");
      var lastY = 0;
      window.addEventListener("scroll", function(){
        var y = window.scrollY;
        if(btn) btn.classList.toggle("visible", y > 400);
        if(isGame && header){
          if(y < lastY) header.classList.add("header--show");
          else header.classList.remove("header--show");
          if(y <= 0) header.classList.remove("header--show");
        }
        lastY = y;
      });
    })();
  </script>

  {# Service Worker #}
  <script>
    if("serviceWorker" in navigator){
      navigator.serviceWorker.register("/sw.js");
    }
  </script>
</body>
</html>
