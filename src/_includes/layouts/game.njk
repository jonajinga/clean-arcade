---
layout: layouts/base.njk
bodyClass: game-active
---
<section class="game-page" data-pagefind-body>
  <div class="game-embed" id="game-embed">
    {# Info overlay #}
    <div class="game-overlay" id="game-overlay">
      <div class="game-overlay__content">
        <p><strong>Controls:</strong> {{ game.controls }}</p>
        <p><strong>About:</strong> {{ game.description }}</p>
        {% if not game.mobileSupport %}<p style="color:var(--slate-600)">Desktop or tablet recommended.</p>{% endif %}
        <button class="game-overlay__close" id="overlay-close">Close</button>
      </div>
    </div>

    <div class="game-embed__viewport">
      <iframe id="game-frame" src="{{ game.gamePath }}" title="Play {{ game.title }}"></iframe>
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "VideoGame",
  "name": "{{ game.title }}",
  "description": "{{ game.description }}",
  "url": "{{ meta.url }}/games/{{ game.slug }}/",
  "genre": "{{ game.category }}",
  "gamePlatform": "Web Browser",
  "playMode": "SinglePlayer",
  "applicationCategory": "Game",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "{{ meta.title }}"
  }
}
</script>

<script>
var GAME_SLUG = "{{ game.slug }}";
</script>
<script src="/assets/js/game-page.js" defer></script>
<script src="/assets/js/game-loader.js" defer></script>
<script src="/assets/js/save-system.js" defer></script>
<script src="/assets/js/my-games.js" defer></script>
<script src="/assets/js/share.js" defer></script>
