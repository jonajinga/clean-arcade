---
layout: layouts/base.njk
bodyClass: game-active
---
<section class="game-page" data-pagefind-body>
  {# Game iframe — edge to edge #}
  <div class="game-embed" id="game-embed">
    <div class="game-embed__bar">
      <div class="game-embed__bar-left">
        <a href="/" class="game-embed__back" title="Back to games">&larr;</a>
        <h1 class="game-embed__title">{{ game.title }}</h1>
        <div class="game-page__badges">
          <span class="badge badge--{{ game.difficulty }}" title="{{ game.difficulty | capitalize }}">{{ game.difficulty }}</span>
          {% if game.multiplayer %}<span class="badge" title="Multiplayer">MP</span>{% endif %}
        </div>
      </div>
      <div class="game-embed__bar-right">
        <button class="icon-btn" id="favorite-btn" onclick="toggleFavorite('{{ game.slug }}')" title="Favorite">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 14s-5.5-3.5-5.5-7A3.5 3.5 0 018 4a3.5 3.5 0 015.5 3c0 3.5-5.5 7-5.5 7z" stroke="currentColor" stroke-width="1.5" fill="none" id="heart-path"/></svg>
        </button>
        <button class="icon-btn" onclick="shareGame('{{ game.title }}', '{{ game.slug }}')" title="Share">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="12" cy="4" r="2" stroke="currentColor" stroke-width="1.2"/><circle cx="4" cy="8" r="2" stroke="currentColor" stroke-width="1.2"/><circle cx="12" cy="12" r="2" stroke="currentColor" stroke-width="1.2"/><path d="M6 7l4-2M6 9l4 2" stroke="currentColor" stroke-width="1.2"/></svg>
        </button>
        <button class="icon-btn" onclick="goFullscreen()" title="Fullscreen (F)">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 6V2h4M10 2h4v4M14 10v4h-4M6 14H2v-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
    <div class="game-embed__viewport" id="game-viewport">
      <iframe
        id="game-frame"
        src="{{ game.gamePath }}"
        title="Play {{ game.title }}"
        sandbox="allow-scripts allow-same-origin allow-popups"
        allow="fullscreen"
        allowfullscreen
      ></iframe>
    </div>
  </div>

  <div class="container">
    {# Mobile warning #}
    {% if not game.mobileSupport %}
      <p class="game-page__notice">Desktop or tablet recommended for this game.</p>
    {% endif %}

    {# Controls + About #}
    <details class="game-page__details">
      <summary>Game info &amp; controls</summary>
      <div class="game-page__info">
        <div><strong>Controls:</strong> {{ game.controls }}</div>
        <div><strong>About:</strong> {{ game.description }}</div>
      </div>
    </details>

    {# Multiplayer UI #}
    {% if game.multiplayer %}
      {% include "partials/multiplayer-ui.njk" %}
    {% endif %}

    {# Related games #}
    <div class="game-page__related">
      <h2>More {{ game.category | capitalize }} Games</h2>
      <div class="game-grid game-grid--small">
        {% set related = games | where("category", game.category) | rejectattr("slug", game.slug) | head(4) %}
        {% for g in related %}
          {% include "partials/game-card.njk" %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% include "partials/save-indicator.njk" %}

<script>
  var GAME_SLUG = "{{ game.slug }}";

  function goFullscreen() {
    var el = document.getElementById("game-embed");
    var rfs = el.requestFullscreen || el.webkitRequestFullscreen || el.msRequestFullscreen;
    if (rfs) {
      rfs.call(el);
    } else {
      /* Fallback: try the iframe directly */
      var iframe = document.getElementById("game-frame");
      var rfs2 = iframe.requestFullscreen || iframe.webkitRequestFullscreen || iframe.msRequestFullscreen;
      if (rfs2) rfs2.call(iframe);
    }
  }

  document.addEventListener("keydown", function(e) {
    if ((e.key === "f" || e.key === "F") && e.target.tagName !== "INPUT" && e.target.tagName !== "TEXTAREA") {
      e.preventDefault();
      goFullscreen();
    }
  });
</script>
<script src="/assets/js/game-loader.js" defer></script>
<script src="/assets/js/save-system.js" defer></script>
<script src="/assets/js/my-games.js" defer></script>
<script src="/assets/js/share.js" defer></script>
{% if game.multiplayer %}
<script type="module" src="/assets/js/multiplayer.js"></script>
{% endif %}
