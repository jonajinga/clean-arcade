---
layout: layouts/page.njk
title: "Blog"
description: "Updates, game guides, and how each game works on Clean Arcade."
permalink: /blog/
---
<div class="content-page">
  <p class="page-intro">Game guides, tips, and updates.</p>

  <div class="blog-grid">
    {% for post in collections.posts %}
      <a href="{{ post.url }}" class="blog-card">
        <h3 class="blog-card__title">{{ post.data.title }}</h3>
        {% if post.data.description %}
          <p class="blog-card__excerpt">{{ post.data.description }}</p>
        {% endif %}
        <div class="blog-card__meta">
          <span>{{ post.content | readingTime }}</span>
        </div>
      </a>
    {% endfor %}
  </div>

  {% if collections.posts.length == 0 %}
    <p class="text-muted" style="padding: var(--space-2xl) 0;">No posts yet.</p>
  {% endif %}
</div>
