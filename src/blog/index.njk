---
layout: layouts/page.njk
title: "Blog"
description: "Updates, game spotlights, and behind-the-scenes from Clean Arcade."
permalink: /blog/
---
<div class="post-list">
  {% for post in collections.posts %}
    <a href="{{ post.url }}" class="post-card">
      <h3 class="post-card__title">{{ post.data.title }}</h3>
      <div class="post-card__meta">
        <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        <span>{{ post.content | readingTime }}</span>
      </div>
      {% if post.data.description %}
        <p class="post-card__excerpt">{{ post.data.description }}</p>
      {% endif %}
    </a>
  {% endfor %}
</div>

{% if collections.posts.length == 0 %}
  <p class="text-muted text-center" style="padding: var(--space-3xl);">No posts yet. Check back soon.</p>
{% endif %}
