---
layout: layouts/page.njk
title: "My Games"
description: "Your recently played and favorite games — saved locally in your browser."
permalink: /my-games/
---
<div class="content-page">
  <p class="page-intro">Your game history and favorites are stored locally in your browser. Nothing is sent to any server.</p>

  <h2 id="favorites">Favorites</h2>
  <div class="game-grid" id="favorites-grid">
    <p class="text-muted" id="no-favorites">No favorites yet. Click the heart on any game to save it here.</p>
  </div>

  <h2 id="recent">Recently Played</h2>
  <div class="game-grid" id="recent-grid">
    <p class="text-muted" id="no-recent">No games played yet.</p>
  </div>
</div>

<script>
  var ALL_GAMES = {{ games | dump | safe }};

  document.addEventListener("DOMContentLoaded", function () {
    var favSlugs = JSON.parse(localStorage.getItem("ca-favorites") || "[]");
    var recentData = JSON.parse(localStorage.getItem("ca-recent") || "[]");

    renderGrid("favorites-grid", "no-favorites", favSlugs);
    renderGrid("recent-grid", "no-recent", recentData.map(function (r) { return r.slug; }));
  });

  function renderGrid(gridId, emptyId, slugs) {
    var grid = document.getElementById(gridId);
    var empty = document.getElementById(emptyId);
    if (!slugs.length) return;
    if (empty) empty.hidden = true;

    slugs.forEach(function (slug) {
      var game = ALL_GAMES.find(function (g) { return g.slug === slug; });
      if (!game) return;
      var card = document.createElement("a");
      card.href = "/games/" + game.slug + "/";
      card.className = "game-card";
      card.innerHTML = '<span class="game-card__list-title">' + game.title + '</span>';
      grid.appendChild(card);
    });
  }
</script>
